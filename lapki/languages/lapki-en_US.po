msgstr "Lapki Settings"

msgid "Налаштування"
msgstr "Settings"

msgid "Дистанція пошуку за замовчуванням (км)"
msgstr "Default search distance (km)"

msgid "Використовується в геопошуку тварин, якщо клієнт не вказав свою відстань."
msgstr "Used in animal geo-search when the client does not specify a distance."

msgid "Тварин на сторінці за замовчуванням"
msgstr "Default animals per page"

msgid "Дефолтний розмір сторінки в REST API (GET /animals) та на фронтенді. Максимум — 100."
msgstr "Default page size in the REST API (GET /animals) and on the frontend. Maximum is 100."

msgid "Email для нотифікацій"
msgstr "Notification email"

msgid "Резервна адреса для сповіщень про нові заявки на усиновлення, якщо в організації не вказано email."
msgstr "Fallback address for new adoption application notifications when the organization has no email set."

